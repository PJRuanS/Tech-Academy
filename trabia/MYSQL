create database sistema_cursos;
use  sistema_cursos;
CREATE TABLE cursos (
    id INT PRIMARY KEY AUTO_INCREMENT,
    nome VARCHAR(100),
    horario VARCHAR(50),
    imagem_url VARCHAR(255), -- Link para a imagem do curso
    categoria VARCHAR(50)   -- Ex: Programação, Design, Business
);

-- Tabela de Alunos
CREATE TABLE alunos (
    id INT PRIMARY KEY AUTO_INCREMENT,
    nome VARCHAR(100),
    email VARCHAR(100) UNIQUE,
    senha VARCHAR(255), -- Sempre armazene como hash!
    telefone VARCHAR(20)
);

-- Tabela de Interesses (Lead/Contato)
-- Geralmente usada para quem ainda não é aluno, mas quer info
CREATE TABLE interesses (
    id INT PRIMARY KEY AUTO_INCREMENT,
    nome VARCHAR(100),
    email VARCHAR(100),
    mensagem TEXT,
    data_envio TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
CREATE TABLE IF NOT EXISTS cursos (
    id INT PRIMARY KEY AUTO_INCREMENT,
    nome VARCHAR(100),
    horario VARCHAR(50),
    imagem_url VARCHAR(255),
    categoria VARCHAR(50)
);

